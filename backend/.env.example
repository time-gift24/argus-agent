# 环境变量模板
# 复制为 .env 并填入真实值: cp .env.example .env
# 开发环境可直接使用: cp .env.dev .env 或直接 make dev

# --- 必填 ---
AES_KEY=                         # AES-256 密钥，base64 编码的 32 字节。生成: python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
JWT_SECRET=                      # JWT 签名密钥，任意非空字符串

# --- 可选 ---
DEV_MODE=false                   # true 启用开发模式（X-Dev-User header 登录，跳过 OIDC）
DATABASE_URL=sqlite:///./argus_agents.db  # 数据库连接字符串

# --- OIDC（生产模式必填）---
OIDC_ISSUER=                     # OIDC Provider issuer URL
OIDC_CLIENT_ID=                  # OAuth2 Client ID
OIDC_CLIENT_SECRET=              # OAuth2 Client Secret
OIDC_REDIRECT_URI=               # OAuth2 回调地址

# --- CORS ---
CORS_ORIGINS=                    # 逗号分隔的允许 origins，空则不加 CORS 中间件
